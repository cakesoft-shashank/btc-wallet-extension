{
  "manifest_version": 3,
  "name": "Bitcoin Wallet by Shashank",
  "description": "Independent open-source non-custodial Bitcoin wallet extension. Not affiliated with Mozilla or Bitcoin.org.",
  "version": "0.1.0",
  "action": {
    "default_title": "Bitcoin Wallet by Shashank",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "clipboardWrite", "alarms"],
  "host_permissions": [
    "https://mempool.space/*",
    "https://mempool.space/testnet4/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{0d6f9de0-31c4-4b6d-8f9f-0d8a9e7d2c41}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}