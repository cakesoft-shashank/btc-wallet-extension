{
  "manifest_version": 3,
  "name": "Bitcoin Wallet",
  "description": "A minimal secure non-custodial Bitcoin wallet extension.",
  "version": "0.1.0",
  "action": {
    "default_title": "Bitcoin Wallet",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "clipboardWrite", "alarms"],
  "host_permissions": [
    "https://mempool.space/*",
    "https://mempool.space/testnet4/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}